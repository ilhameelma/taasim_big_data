   "source": [
    "CELLULE 2 — Fonctions de transformation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "34f80e31",
   "metadata": {},
   "outputs": [],
   "source": [
    "import math\n",
    "\n",
    "# paramètres ajustables\n",
    "ROTATION_DEGREES = 12\n",
    "SCALE_X = 0.80\n",
    "SCALE_Y = 0.85\n",
    "OFFSET_X = 0.05\n",
    "OFFSET_Y = 0.04\n",
    "\n",
    "theta = math.radians(ROTATION_DEGREES)\n",
    "\n",
    "def transform_point(lon_p, lat_p):\n",
    "    \"\"\"Transformation Porto → Casa avec rotation + scale + offset\"\"\"\n",
    "\n",
    "    # 1) Normalisation Porto\n",
    "    x = (lon_p - PORTO_LON_MIN) / (PORTO_LON_MAX - PORTO_LON_MIN)\n",
    "    y = (lat_p - PORTO_LAT_MIN) / (PORTO_LAT_MAX - PORTO_LAT_MIN)\n",
    "\n",
    "    # 2) Rotation\n",
    "    xr = x * math.cos(theta) - y * math.sin(theta)\n",
    "    yr = x * math.sin(theta) + y * math.cos(theta)\n",
    "\n",
    "    # 3) Compression des distances\n",
    "    xs = xr * SCALE_X\n",
    "    ys = yr * SCALE_Y\n",
    "\n",
    "    # 4) Offset pour éviter la mer\n",
    "    xo = xs + OFFSET_X\n",
    "    yo = ys + OFFSET_Y\n",
    "\n",
    "    # 5) Projection Casa\n",
    "    lon_c = CASA_LON_MIN + xo * (CASA_LON_MAX - CASA_LON_MIN)\n",
    "    lat_c = CASA_LAT_MIN + yo * (CASA_LAT_MAX - CASA_LAT_MIN)\n",
    "\n",
    "    return round(lon_c, 6), round(lat_c, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "fca2121b",
   "metadata": {},
   "source": [
    "CELLULE 3 — UDF PySpark pour le POLYLINE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "7737e79a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def remap_polyline(polyline_str):\n",
    "    \"\"\"Transforme un trajet Porto → Casa avec rotation, scale et offset\"\"\"\n",
    "    if polyline_str is None or polyline_str == \"[]\":\n",
    "        return None\n",
    "\n",
    "    try:\n",
    "        points = json.loads(polyline_str)\n",
    "        remapped = []\n",
    "\n",
    "        for lon_p, lat_p in points:\n",
    "            lon_c, lat_c = transform_point(lon_p, lat_p)\n",
    "            remapped.append([lon_c, lat_c])\n",
    "\n",
    "        return json.dumps(remapped)\n",
    "\n",
    "    except:\n",
    "        return None\n",
    "\n",
    "remap_udf = F.udf(remap_polyline, StringType())"
   ]
  },
