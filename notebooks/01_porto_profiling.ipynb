   "source": [
    "import os\n",
    "import json\n",
    "from pyspark.sql.functions import from_unixtime, hour, dayofweek\n",
    "\n",
    "# Détecter l'environnement automatiquement\n",
    "BASE_PATH = \"/home/jovyan/work\"\n",
    "os.makedirs(f\"{BASE_PATH}/image\", exist_ok=True)\n",
    "\n",
    "df_time = df.withColumn(\"datetime\", from_unixtime(F.col(\"TIMESTAMP\"))) \\\n",
    "            .withColumn(\"hour_of_day\", hour(\"datetime\")) \\\n",
    "            .withColumn(\"day_of_week\", dayofweek(\"datetime\"))\n",
    "\n",
    "# ── Graphe 1 : demande par heure ──────────────────────────────\n",
    "hourly = df_time.groupBy(\"hour_of_day\").count().orderBy(\"hour_of_day\").toPandas()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "ax.fill_between(hourly[\"hour_of_day\"], hourly[\"count\"], alpha=0.3, color=\"#1D9E75\")\n",
    "ax.plot(hourly[\"hour_of_day\"], hourly[\"count\"], color=\"#0F6E56\", linewidth=2)\n",
    "ax.set_title(\"Demande de taxis par heure — Porto (proxy Casablanca)\", fontsize=13)\n",
    "ax.set_xlabel(\"Heure de la journée\")\n",
    "ax.set_ylabel(\"Nombre de trajets\")\n",
    "ax.set_xticks(range(0, 24))\n",
    "ax.axvspan(7, 9, alpha=0.1, color=\"orange\", label=\"Rush matin\")\n",
    "ax.axvspan(17, 19, alpha=0.1, color=\"red\", label=\"Rush soir\")\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(f\"{BASE_PATH}/image/hourly_demand.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "# ── Graphe 2 : demande par jour ───────────────────────────────\n",
    "daily = df_time.groupBy(\"day_of_week\").count().orderBy(\"day_of_week\").toPandas()\n",
    "jours = [\"Dim\", \"Lun\", \"Mar\", \"Mer\", \"Jeu\", \"Ven\", \"Sam\"]\n",
    "daily[\"jour\"] = [jours[d-1] for d in daily[\"day_of_week\"]]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "ax.bar(daily[\"jour\"], daily[\"count\"], color=\"#534AB7\")\n",
    "ax.set_title(\"Demande par jour de la semaine — Porto\", fontsize=13)\n",
    "ax.set_ylabel(\"Nombre de trajets\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(f\"{BASE_PATH}/image/weekly_demand.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ── 1. demand_curve_hourly.json ───────────────────────────────\n",
    "max_hourly = hourly[\"count\"].max()\n",
    "hourly[\"ratio\"] = (hourly[\"count\"] / max_hourly).round(3)\n",
    "\n",
    "demand_hourly = dict(zip(\n",
    "    hourly[\"hour_of_day\"].astype(int),\n",
    "    hourly[\"ratio\"]\n",
    "))\n",
    "\n",
    "with open(f\"{BASE_PATH}/data/demand_curve_hourly.json\", \"w\") as f:\n",
    "    json.dump(demand_hourly, f, indent=2)\n",
    "\n",
    "print(\"demand_curve_hourly.json sauvegardé\")\n",
    "print(demand_hourly)\n",
    "\n",
    "# ── 2. demand_curve_daily.json ────────────────────────────────\n",
    "max_daily = daily[\"count\"].max()\n",
    "daily[\"ratio\"] = (daily[\"count\"] / max_daily).round(3)\n",
    "\n",
    "# day_of_week dans Porto : 1=Dimanche, 2=Lundi ... 7=Samedi\n",
    "# On convertit en 0=Lundi ... 6=Dimanche (convention standard)\n",
    "day_mapping = {1: 6, 2: 0, 3: 1, 4: 2, 5: 3, 6: 4, 7: 5}\n",
    "\n",
    "demand_daily = {}\n",
    "for _, row in daily.iterrows():\n",
    "    standard_day = day_mapping[int(row[\"day_of_week\"])]\n",
    "    demand_daily[standard_day] = round(row[\"ratio\"], 3)\n",
    "\n",
    "with open(f\"{BASE_PATH}/data/demand_curve_daily.json\", \"w\") as f:\n",
    "    json.dump(demand_daily, f, indent=2)\n",
    "\n",
    "print(\"\\ndemand_curve_daily.json sauvegardé\")\n",
    "jours = [\"Lun\", \"Mar\", \"Mer\", \"Jeu\", \"Ven\", \"Sam\", \"Dim\"]\n",
    "for day_num, ratio in sorted(demand_daily.items()):\n",
    "    print(f\"  {jours[day_num]} : {ratio}\")"
   ]
  },
